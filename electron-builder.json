{
  "appId": "com.lordpainreborn.aioms",
  "productName": "AIOMS",
  "executableName": "AIOMS",
  "files": [
    "main.js",
    "package.json",
    "node_modules/**/*"
  ],
  "directories": {
    "output": "dist"
  },
  "win": {
    "icon": "public/icon.png",
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "AIOMS.exe"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "public/icon.png",
    "uninstallerIcon": "public/icon.png"
  }
}
