generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShopRole {
  SUPER_ADMIN
  SHOP_OWNER
  STAFF
}

enum ProductCategory {
  PHONE
  ACCESSORY
  PART
}

enum RepairStatus {
  PENDING
  CHECKING
  REPAIRING
  READY
  DELIVERED
}

enum ImeiStatus {
  AVAILABLE
  SOLD
  RESERVED
}

model Shop {
  id        String   @id @default(cuid())
  name      String
  ownerName String
  phone     String
  createdAt DateTime @default(now())

  users    User[]
  products Product[]
  sales    Sale[]
  tickets  RepairTicket[]
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         ShopRole @default(STAFF)
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())

  assignedTickets RepairTicket[] @relation("Technician")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  sku           String?
  category      ProductCategory
  price         Float
  cost          Float
  stockQuantity Int             @default(0)
  shopId        String
  shop          Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())

  imeis        IMEI[]
  saleItems    SaleItem[]
  repairParts  RepairPart[]

  @@unique([shopId, sku])
}

model IMEI {
  id        String     @id @default(cuid())
  imeiCode  String     @unique
  status    ImeiStatus @default(AVAILABLE)
  productId String
  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model RepairTicket {
  id               String       @id @default(cuid())
  customerName     String
  customerPhone    String
  deviceModel      String
  issueDescription String
  status           RepairStatus @default(PENDING)
  estimateCost     Float?
  shopId           String
  shop             Shop         @relation(fields: [shopId], references: [id], onDelete: Cascade)

  technicianId String?
  technician   User?   @relation("Technician", fields: [technicianId], references: [id])

  usedParts RepairPart[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model RepairPart {
  id             String       @id @default(cuid())
  repairTicketId String
  repairTicket   RepairTicket @relation(fields: [repairTicketId], references: [id], onDelete: Cascade)
  productId      String
  product        Product      @relation(fields: [productId], references: [id])
  quantity       Int          @default(1)
}

model Sale {
  id            String   @id @default(cuid())
  totalAmount   Float
  paymentMethod String
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  items SaleItem[]
}

model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  sale      Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}
